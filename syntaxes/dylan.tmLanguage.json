{
    "comment-1": "MAKE SURE YOU'RE EDITING dylan.tmLanguage.template.json,",
    "comment-2": "then run ./gen_tmLanguage.sh to generate dylan.tmLanguage.json",
    "fileTypes": [
        "dylan"
    ],
    "keyEquivalent": "^~D",
    "name": "Dylan",
    "patterns": [
        {
            "match": "(?i:^(module):\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))",
            "captures": {
                "1": { "name": "keyword.package.dylan" },
                "2": { "name": "entity.name.type.package.dylan" }
            }
        },
        {
            "comment": "other headers besides Module",
            "match": "(?i:^([a-z][-a-z0-9]*):)",
            "captures": {
                "1": { "name": "keyword.package.dylan" }
            }
        },
        { "include": "#comment-line" },
        { "include": "#comment-block" },
        {
            "begin": "(?i:^(define)\\s+(macro)\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))",
            "beginCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "2": { "name": "keyword.other.dylan" },
                "3": { "name": "variable.other.dylan" }
            },
            "end": "(?i:^(end)(\\s+(macro))?(\\s+(\\3))?(?:[\\s(),.;:#{}\\[\\]]))",
            "endCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "3": { "name": "keyword.other.dylan" },
                "5": { "name": "variable.other.dylan" }
            },
            "name": "meta.definition.macro.dylan",
            "patterns": [
                {
                    "match": "\\?((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*):",
                    "captures": {
                        "1": { "name": "variable.other.dylan" }
                    }
                },
                {
                    "match": "(?i:\\?:(expression|variable|name|token|body|case-body|macro))",
                    "captures": {
                        "1": { "name": "variable.other.dylan" }
                    }
                },
                {
                    "match": "^\\s*((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*):\\s*$",
                    "captures": {
                        "1": { "name": "keyword.other.dylan" }
                    }
                },
                { "include": "#body" }
            ]
        },
        {
            "begin": "(?i)^(define)\\s+((thread)\\s+)?(constant|variable)\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)(\\s+|$)",
            "beginCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "3": { "name": "keyword.other.dylan" },
                "4": { "name": "storage.modifier.dylan" },
                "5": { "name": "variable.other.dylan" }
            },
            "end_": "See 'limitations' in CONTRIBUTING.rst",
            "end": ";",
            "endCaptures": {
                "0": { "name": "meta.punctuation.dylan" }
            },
            "name": "meta.definition.variable.dylan",
            "patterns": [
                { "include": "#body" }
            ]
        },
        {
            "begin": "(?i:^(define(\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))*\\s+generic)\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))",
            "beginCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "4": { "name": "variable.other.dylan" }
            },
            "end_": "See 'limitations' in CONTRIBUTING.rst",
            "end": ";",
            "endCaptures": {
                "0": { "name": "meta.punctuation.dylan" }
            },
            "name": "meta.definition.function.dylan",
            "patterns": [
                { "include": "#parameter-list-words" },
                { "include": "#body" }
            ]
        },
        {
            "comment": "define method - one line - no way to do params accurately?",
            "match": "(?i:^(define(\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))*\\s+(method|function))\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)\\s*\\((.*?)\\) *(=> *\\((.*?)\\))?.*(end)(.*)(;)?$)",
            "captures": {
                "1": { "name": "keyword.other.dylan" },
                "5": { "name": "variable.other.dylan" },
                "6": { "name": "variable.other.dylan" },
                "9": { "name": "keyword.other.dylan" },
                "11": { "name": "meta.punctuation.dylan" }
            },
            "name": "meta.definition.function.dylan"
        },
        {
            "comment": "define method - multi line",
            "begin": "(?i:^(define(\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))*\\s+(method|function))\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)(\\s+|$))",
            "beginCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "3": { "name": "keyword.other.dylan" },
                "4": { "name": "keyword.other.dylan" },
                "5": { "name": "variable.other.dylan" }
            },
            "end": "(?i:^(end)(\\s+(\\4))?(\\s+(\\5))?(?:[\\s(),.;:#{}\\[\\]]))",
            "endCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "3": { "name": "keyword.other.dylan" },
                "5": { "name": "variable.other.dylan" }
            },
            "name": "meta.definition.function.dylan",
            "patterns": [
                { "include": "#parameter-list-words" },
                { "include": "#body" }
            ]
        },
        {
            "comment": "define class - single line - no slots - must precede multi-line define class",
            "match": "(?i:^(define)(\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))*\\s+(class)\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)\\s*[(](((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)(,\\s*((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))*)[)]\\s*(end)(\\s+(class))?(\\s+(\\5))?;$)",
            "captures": {
                "1": { "name": "keyword.other.dylan" },
                "3": { "name": "storage.modifier.dylan" },
                "4": { "name": "keyword.other.dylan" },
                "5": { "name": "variable.other.dylan" },
                "6": { "name": "entity.other.inherited-class" },
                "10": { "name": "keyword.other.dylan" },
                "12": { "name": "keyword.other.dylan" },
                "14": { "name": "variable.other.dylan" }
            },
            "name": "meta.definition.class.dylan"
        },
        {
            "comment": "define class - multi line - must follow single line define class",
            "begin": "^(define)(\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))*\\s+(class)\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)($|\\s+[(](((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)(,\\s*((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))*)[)])?",
            "beginCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "3": { "name": "storage.modifier.dylan" },
                "4": { "name": "keyword.other.dylan" },
                "5": { "name": "variable.other.dylan" },
                "7": { "name": "entity.other.inherited-class" }
            },
            "end": "(?i:^(end)(\\s+(class))?(\\s+(\\5))?($|(?:[\\s(),.;:#{}\\[\\]])))",
            "endCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "3": { "name": "keyword.other.dylan" },
                "5": { "name": "variable.other.dylan" }
            },
            "name": "meta.definition.class.dylan",
            "patterns": [
                { "include": "#slot" }
            ]
        },
        {
            "begin": "(?i:^(define)\\s+((library|module)\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)))",
            "beginCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "3": { "name": "keyword.other.dylan" },
                "4": { "name": "entity.name.type.package.dylan" }
            },
            "end": "(?i:^(end)(\\s+(\\3))?(\\s+(\\4))?($|(?:[\\s(),.;:#{}\\[\\]])))",
            "endCaptures": {
                "1": { "name": "keyword.other.dylan" },
                "3": { "name": "keyword.other.dylan" },
                "5": { "name": "entity.name.type.package.dylan" }
            },
            "name": "meta.namespace.dylan",
            "patterns": [
                { "include": "#body" }
            ]
        }
    ],
    "repository": {
        "body": {
            "patterns": [
                { "include": "#let" },
                { "include": "#comment-line" },
                { "include": "#comment-block" },
                { "include": "#string" },
                { "include": "#symbol" },
                { "include": "#boolean" },
                { "include": "#hex-oct-bin" },
                { "include": "#decimal" },
                { "include": "#character" },
                { "include": "#drm-control-flow-words" },
                { "include": "#drm-definer-words" },
                { "include": "#drm-classes" },
                { "include": "#drm-functions" }
            ]
        },
        "slot": {
            "begin": "(?i:^\\s*((constant|sealed)\\s+)*(slot)\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)(\\s+(::)\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*))?)",
            "beginCaptures": {
                "2": { "name": "storage.modifier.dylan" },
                "3": { "name": "keyword.other.dylan" },
                "4": { "name": "variable.other.dylan" },
                "6": { "name": "meta.punctuation.dylan" },
                "7": { "name": "storage.type.dylan" }
            },
            "end_": "See 'limitations' in CONTRIBUTING.rst",
            "end": ";",
            "endCaptures": {
                "0": { "name": "meta.punctuation.dylan" }
            },
            "patterns": [
                { "include": "#body" }
            ]
        },
        "let": {
            "match": "\\s(let)\\s+((?i:[a-z]|[0-9]+[a-z][a-z]|[!&*<>|^$%@_]+[a-z])[-+~?/=!&*<>|^$%@_a-z0-9]*)($|\\s+(::\\s+(\\S+)\\s+)?)",
            "captures": {
                "1": { "name": "keyword.other.dylan" },
                "2": { "name": "variable.other.dylan" },
                "5": { "name": "storage.type.dylan" }
            }
        },
        "comment-line": {
            "match": "^\\s*(//.*)$",
            "name": "comment.line.double-slash.dylan"
        },
        "comment-block": {
            "begin": "(?<=^|\\s|\\()/\\*",
            "end": "\\*/"
        },
        "string": {
            "begin": "(#[rR])?\"",
            "end": "\"",
            "name": "string.quoted.double.dylan",
            "patterns": [
                { "include": "#escape" }
            ]
        },
        "symbol": {
            "begin": "#\"+",
            "end": "\"+",
            "name": "constant.other.dylan",
            "patterns": [
                { "include": "#escape" }
            ]
        },
        "escape": {
            "match": "\\\\(?i:.|<[0-9a-f]*>)",
            "name": "constant.character.escape.dylan"
        },
        "boolean": {
            "match": "(?i:#t|#f)",
            "name": "constant.language.dylan"
        },
        "hex-oct-bin": {
            "match": "(?i:(#x[0-9a-f_]+|#o[0-7_]+|#b[01_]+)($|(?:[\\s(),.;:#{}\\[\\]])))",
            "name": "constant.numeric.dylan"
        },
        "decimal": {
            "match": "(^|(?:[\\s(),.;:#{}\\[\\]]))((([0-9_]+(\\.[0-9_]*)?)|(\\.[0-9_]+))([desx][+-]?[0-9_]+)?)($|(?:[\\s(),.;:#{}\\[\\]]))",
            "name": "constant.numeric.dylan"
        },
        "character": {
            "match": "'(\\\\<[0-9a-fA-F]*>|\\\\.|.)'",
            "name": "constant.character.dylan"
        },
        "parameter-list-words": {
            "match": "(?i:#next|#rest|#key|#all-keys)",
            "name": "keyword.control.dylan"
        },
        "drm-control-flow-words": {
            "match": "(?<=^|[,.()\\s])(above|afterwards|begin|below|block|by|case|cleanup|else|elseif|exception|finally|for|from|keyed-by|if|in|otherwise|select|then|to|unless|until:?|using|when|while:?)(?=$|[;,()\\s])",
            "name": "keyword.control.dylan"
        },
        "drm-definer-words": {
            "match": "(?<=^|[,.(\\s])(class|constant|create|default:|define|each-subclass|exclude:|export|export:|function|generic|import:|inherited|init-function:|init-keyword:|init-value:|instance|keyword|let(\\s+handler)?|library|local|macro|method|module|prefix:|rename:|required|required-init-keyword:|sealed|setter:|slot|type:|use|variable|virtual)(?=$|[;,.()\\s])",
            "name": "keyword.other.dylan"
        },
        "drm-classes": {
            "match": "<(abort|array|boolean|byte-string|character|class|collection|complex|condition|deque|double-float|empty-list|error|explicit-key-collection|extended-float|float|function|generic-function|integer|list|method|mutable-collection|mutable-explicit-key-collection|mutable-sequence|number|object-table|object|pair|range|rational|real|restart|sealed-object-error|sequence|serious-condition|simple-error|simple-object-vector|simple-restart|simple-vector|simple-warning|single-float|singleton|stretchy-collection|stretchy-vector|string|symbol|table|type-error|type|unicode-string|vector|warning)>",
            "name": "support.class.dylan"
        },
        "drm-functions": {
            "match": "(?<=^|[~,.(\\[\\s])(abort|abs|add|add!|add-method|add-new|add-new!|all-superclasses|always|any\\?|applicable-method\\?|apply|aref|aref-setter|as|as-lowercase|as-lowercase!|as-uppercase|as-uppercase!|ash|backward-iteration-protocol|break|ceiling|ceiling/|cerror|check-type|choose|choose-by|complement|compose|concatenate|concatenate-as|condition-format-arguments|condition-format-string|conjoin|copy-sequence|curry|default-handler|dimension|dimensions|direct-subclasses|direct-superclasses|disjoin|do|do-handlers|element|element-setter|empty\\?|error|even\\?|every\\?|false-or|fill!|find-key|find-method|first|first-setter|floor|floor/|forward-iteration-protocol|function-arguments|function-return-values|function-specializers|gcd|generic-function-mandatory-keywords|generic-function-methods|head|head-setter|identity|initialize|instance\\?|integral\\?|intersection|key-sequence|key-test|last|last-setter|lcm|limited|list|logand|logbit\\?|logior|lognot|logxor|make|map|map-as|map-into|max|member\\?|merge-hash-codes|min|modulo|negative|negative\\?|next-method|object-class|object-hash|odd\\?|one-of|pair|pop|pop-last|positive\\?|push|push-last|range|rank|rcurry|reduce|reduce1|remainder|remove|remove!|remove-duplicates|remove-duplicates!|remove-key!|remove-method|replace-elements!|replace-subsequence!|restart-query|return-allowed\\?|return-description|return-query|reverse|reverse!|round|round/|row-major-index|second|second-setter|shallow-copy|signal|singleton|size|size-setter|slot-initialized\\?|sort|sort!|sorted-applicable-methods|subsequence-position|subtype\\?|table-protocol|tail|tail-setter|third|third-setter|truncate|truncate/|type-error-expected-type|type-error-value|type-for-copy|type-union|union|values|vector|zero\\?)(?=$|[;,.()\\s\\]])",
            "name": "support.function.dylan"
        }
    },
    "scopeName": "source.dylan",
    "uuid": "475B8369-3520-4B4C-BBA1-1D1229C6F397"
}
