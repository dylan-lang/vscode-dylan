        "comment-block": {
            "begin": "(?<=^|\\s|\\()/\\*",
            "end": "\\*/"
        },
        "string": {
            "begin": "(#[rR])?\"",
            "end": "\"",
            "name": "string.quoted.double.dylan",
            "patterns": [
                { "include": "#escape" }
            ]
        },
        "symbol": {
            "begin": "#\"+",
            "end": "\"+",
            "name": "constant.other.dylan",
            "patterns": [
